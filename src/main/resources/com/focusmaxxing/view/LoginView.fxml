<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20" styleClass="root" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusmaxxing.controller.LoginController">
    <VBox alignment="CENTER" styleClass="card" spacing="15" maxWidth="400">
        <Label text="Welcome to FocusMaxxing" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #4a5c50;"/>
        <Label text="Sign in to continue" style="-fx-text-fill: #888;"/>
        
        <TextField fx:id="usernameField" promptText="Username" styleClass="text-field-custom"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field-custom"/>
        
        <Label fx:id="errorLabel" style="-fx-text-fill: #e57373;" wrapText="true"/>
        
        <Button text="Login" styleClass="button-primary" maxWidth="Infinity" onAction="#handleLogin"/>
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?"/>
            <Hyperlink text="Register" style="-fx-text-fill: #78a890;" onAction="#goToRegister"/>
        </HBox>
    </VBox>
</VBox>
